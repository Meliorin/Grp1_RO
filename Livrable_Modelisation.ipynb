        "\n",
        "    ax.set_title(title)\n",
        "    ax.set_xlabel('x')\n",
        "    ax.set_ylabel('y')\n",
        "    ax.legend(loc='best')\n",
        "\n",
        "\n",
        "def plot_solution(instance: CVRPInstance, routes: Sequence[Sequence[int]], ax=None, title: str = 'Solution'):\n",
        "    if not HAS_MATPLOTLIB:\n",
        "        print(f'[Graphique ignoré] {title}')\n",
